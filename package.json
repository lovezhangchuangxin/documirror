{
  "name": "documirror",
  "version": "0.1.0",
  "private": true,
  "description": "CLI and workspace packages for building translated documentation mirrors",
  "type": "module",
  "packageManager": "pnpm@10.22.0",
  "engines": {
    "node": ">=22.14.0"
  },
  "license": "MIT",
  "author": {
    "name": "keqing",
    "email": "2911331070@qq.com"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "changeset": "changeset",
    "clean": "pnpm -r --filter './packages/*' clean && rm -rf .artifacts",
    "commitlint": "commitlint --edit",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "lint-staged": "lint-staged",
    "pack:cli": "rm -rf .artifacts && mkdir -p .artifacts && pnpm --filter @documirror/cli build && pnpm --filter @documirror/cli pack --pack-destination .artifacts",
    "prepare": "simple-git-hooks",
    "release": "changeset publish",
    "release:check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm pack:cli && pnpm smoke:cli",
    "smoke:cli": "node ./scripts/smoke-cli-package.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "version-packages": "changeset version"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,mts,cts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged && pnpm lint && pnpm format:check",
    "commit-msg": "pnpm exec commitlint --edit $1",
    "pre-push": "pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/fs-extra": "^11.0.4",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.5.0",
    "@types/prompts": "^2.4.9",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "lint-staged": "^16.4.0",
    "publint": "^0.3.12",
    "prettier": "^3.8.1",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.21.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  }
}
