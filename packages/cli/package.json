{
  "name": "@documirror/cli",
  "version": "0.1.0",
  "description": "CLI for building translated mirrors of static documentation sites",
  "private": false,
  "type": "module",
  "bin": {
    "documirror": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "cli",
    "crawler",
    "docs",
    "i18n",
    "openai",
    "static-site",
    "translation"
  ],
  "license": "MIT",
  "homepage": "https://github.com/lovezhangchuangxin/documirror#readme",
  "bugs": {
    "url": "https://github.com/lovezhangchuangxin/documirror/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lovezhangchuangxin/documirror.git"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "clean": "rm -rf dist",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "defu": "^6.1.4",
    "dom-serializer": "^3.0.0",
    "entities": "^8.0.0",
    "fast-glob": "^3.3.3",
    "file-type": "^21.3.3",
    "fs-extra": "^11.3.4",
    "htmlparser2": "^11.0.0",
    "mime-types": "^3.0.2",
    "nanoid": "^5.1.7",
    "openai": "^5.12.2",
    "ora": "^9.3.0",
    "p-limit": "^7.3.0",
    "p-queue": "^9.1.0",
    "pathe": "^2.0.3",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "robots-parser": "^3.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@documirror/adapters-filequeue": "workspace:*",
    "@documirror/adapters-openai": "workspace:*",
    "@documirror/core": "workspace:*",
    "@documirror/crawler": "workspace:*",
    "@documirror/i18n": "workspace:*",
    "@documirror/parser": "workspace:*",
    "@documirror/shared": "workspace:*",
    "@documirror/site-builder": "workspace:*",
    "@documirror/templates": "workspace:*"
  }
}
