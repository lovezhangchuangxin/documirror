{
  "name": "@documirror/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts --out-dir dist --clean",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@documirror/adapters-filequeue": "workspace:*",
    "@documirror/crawler": "workspace:*",
    "@documirror/i18n": "workspace:*",
    "@documirror/parser": "workspace:*",
    "@documirror/shared": "workspace:*",
    "@documirror/site-builder": "workspace:*",
    "@documirror/templates": "workspace:*",
    "defu": "^6.1.4",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.2",
    "nanoid": "^5.1.6",
    "pathe": "^2.0.3",
    "p-limit": "^7.2.0",
    "zod": "^4.1.11"
  }
}
