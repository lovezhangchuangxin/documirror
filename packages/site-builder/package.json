{
  "name": "@documirror/site-builder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts --out-dir dist --clean",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@documirror/shared": "workspace:*",
    "cheerio": "^1.2.0",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.4",
    "pathe": "^2.0.3"
  }
}
